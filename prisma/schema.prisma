generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum UserRole {
  user
  admin
}

enum SubmissionStatus {
  new
  in_review
  resolved
}

enum SubmissionPriority {
  low
  medium
  high
}

enum ActorRole {
  user
  admin
  system
}

enum PaymentStatus {
  created
  paid
  failed
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  role         UserRole      @default(user)
  passwordHash String
  createdAt    DateTime      @default(now())
  submissions  Submission[]
  paymentOrders PaymentOrder[]
}

model Submission {
  id         String             @id @default(cuid())
  userId     String?
  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName   String
  email      String
  whatsapp   String
  visaType   String
  message    String?
  fileName   String?
  status     SubmissionStatus   @default(new)
  priority   SubmissionPriority @default(medium)
  assignedTo String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  updates    SubmissionUpdate[]

  @@index([userId])
  @@index([status, createdAt])
}

model SubmissionUpdate {
  id           String           @id @default(cuid())
  submissionId String
  submission   Submission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  status       SubmissionStatus
  note         String
  actorRole    ActorRole
  actorName    String
  createdAt    DateTime         @default(now())

  @@index([submissionId, createdAt])
}

model RateLimit {
  key        String   @id
  bucket     String
  identifier String
  count      Int
  resetAt    DateTime
  updatedAt  DateTime @updatedAt

  @@index([bucket, identifier])
}

model PaymentOrder {
  id              String        @id @default(cuid())
  razorpayOrderId String        @unique
  razorpayPaymentId String?     @unique
  planName        String
  amount          Int
  currency        String        @default("INR")
  status          PaymentStatus @default(created)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  email           String?
  paidAt          DateTime?
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  events          PaymentEvent[]

  @@index([createdAt])
  @@index([status, createdAt])
}

model PaymentEvent {
  id             String       @id @default(cuid())
  paymentOrderId String
  paymentOrder   PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
  eventType      String
  payload        String
  createdAt      DateTime     @default(now())

  @@index([paymentOrderId, createdAt])
}

// ─── CMS Content Models ───────────────────────────────────────

model SiteService {
  id              String   @id @default(cuid())
  slug            String   @unique
  flag            String
  title           String
  subtitle        String
  description     String   @default("")
  accent          String   @default("accent-uk")
  price           String   @default("")
  reasonStats     String   @default("[]") // JSON array of strings
  differentiators String   @default("[]") // JSON array of strings
  pricingAnalysis String   @default("")
  pricingFull     String   @default("")
  pricingExpress  String   @default("")
  testimonials    String   @default("[]") // JSON array of {name, role, feedback}
  sortOrder       Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  faqItems        FaqItem[]

  @@index([sortOrder])
  @@index([published])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  country   String   @default("")
  role      String   @default("")
  date      String   @default("")
  feedback  String
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model VideoTestimonial {
  id           String   @id @default(cuid())
  title        String
  thumbnailUrl String   @default("")
  videoUrl     String
  country      String   @default("")
  featured     Boolean  @default(false)
  sortOrder    Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, sortOrder])
}

model BlogPostEntry {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String   @default("[]") // JSON array of {heading, paragraphs[]}
  publishedAt String
  readTime    String   @default("")
  cta         String   @default("")
  status      String   @default("published") // draft | published
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model FaqItem {
  id        String       @id @default(cuid())
  question  String
  answer    String
  serviceId String?
  service   SiteService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  sortOrder Int          @default(0)
  published Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([serviceId, sortOrder])
  @@index([published, sortOrder])
}

model PricingTier {
  id        String   @id @default(cuid())
  name      String
  price     String
  note      String   @default("")
  features  String   @default("[]") // JSON array of strings
  popular   Boolean  @default(false)
  amountInr Int      @default(0)
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model SiteConfig {
  key       String   @id
  value     String   // JSON value
  label     String   @default("") // Human-readable label for admin UI
  updatedAt DateTime @updatedAt
}
