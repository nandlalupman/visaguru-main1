generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root@localhost:3306/visaguru_db"
}

enum UserRole {
  user
  admin
  @@map("user_role")
}

enum SubmissionStatus {
  new
  in_review
  resolved
  @@map("submission_status")
}

enum SubmissionPriority {
  low
  medium
  high
  @@map("submission_priority")
}

enum ActorRole {
  user
  admin
  system
  @@map("submissionupdate_actorRole")
}

enum PaymentStatus {
  created
  paid
  failed
  @@map("paymentorder_status")
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  role         UserRole       @default(user)
  passwordHash String
  createdAt    DateTime       @default(now())
  paymentOrders PaymentOrder[]
  submissions  Submission[]

  @@map("user")
}

model Submission {
  id               String              @id @default(cuid())
  userId           String?
  fullName         String
  email            String
  whatsapp         String
  visaType         String
  message          String?
  fileName         String?
  status           SubmissionStatus    @default(new)
  priority         SubmissionPriority  @default(medium)
  assignedTo       String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User?               @relation(fields: [userId], references: [id])
  updates          SubmissionUpdate[]

  @@index([userId])
  @@index([status, createdAt])
  @@map("submission")
}

model SubmissionUpdate {
  id           String           @id @default(cuid())
  submissionId String
  submission   Submission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  status       SubmissionStatus
  note         String
  actorRole    ActorRole
  actorName    String
  createdAt    DateTime         @default(now())

  @@index([submissionId, createdAt])
  @@map("submissionupdate")
}

model RateLimit {
  key        String   @id
  bucket     String
  identifier String
  count      Int
  resetAt    DateTime
  updatedAt  DateTime @updatedAt

  @@index([bucket, identifier])
  @@map("ratelimit")
}

model PaymentOrder {
  id                String        @id @default(cuid())
  razorpayOrderId   String        @unique
  razorpayPaymentId String?        @unique
  planName          String
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(created)
  userId            String?
  user              User?         @relation(fields: [userId], references: [id])
  email             String?
  paidAt            DateTime?
  failureReason     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  events          PaymentEvent[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@map("paymentorder")
}

model PaymentEvent {
  id             String       @id @default(cuid())
  paymentOrderId String
  paymentOrder   PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
  eventType      String
  payload        String
  createdAt      DateTime     @default(now())

  @@index([paymentOrderId, createdAt])
  @@map("paymentevent")
}

model SiteService {
  id              String   @id @default(cuid())
  slug            String   @unique
  flag            String
  title           String
  subtitle        String
  description     String   @default("")
  accent          String   @default("accent-uk")
  price           String   @default("")
  reasonStats     String   @default("[]")
  differentiators String   @default("[]")
  pricingAnalysis String   @default("")
  pricingFull     String   @default("")
  pricingExpress  String   @default("")
  testimonials    String   @default("[]")
  sortOrder       Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  faqItems        FaqItem[]

  @@index([sortOrder])
  @@index([published])
  @@map("siteservice")
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  country   String   @default("")
  role      String   @default("")
  date      String   @default("")
  feedback  String
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
  @@map("testimonial")
}

model VideoTestimonial {
  id           String   @id @default(cuid())
  title        String
  thumbnailUrl String   @default("")
  videoUrl     String
  country      String   @default("")
  featured     Boolean  @default(false)
  sortOrder    Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, sortOrder])
  @@map("videotestimonial")
}

model BlogPostEntry {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  content     String   @default("[]")
  publishedAt String
  readTime    String   @default("")
  cta         String   @default("")
  status      String   @default("published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@map("blogpostentry")
}

model FaqItem {
  id        String       @id @default(cuid())
  question  String
  answer    String
  serviceId String?
  service   SiteService? @relation(fields: [serviceId], references: [id])
  sortOrder Int          @default(0)
  published Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([serviceId, sortOrder])
  @@index([published, sortOrder])
  @@map("faqitem")
}

model PricingTier {
  id        String   @id @default(cuid())
  name      String
  price     String
  note      String   @default("")
  features  String   @default("[]")
  popular   Boolean  @default(false)
  amountInr Int      @default(0)
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
  @@map("pricingtier")
}

model SiteConfig {
  key       String   @id
  value     String
  label     String   @default("")
  updatedAt DateTime @updatedAt

  @@map("siteconfig")
}
